default_platform(:ios)

platform :ios do
  desc "Build app for TestFlight"
  lane :build_testflight do
    setup_ci if is_ci

    profile_uuid = ENV["PROVISIONING_PROFILE_SPECIFIER"]
    bundle_id = "read-en.ru"

    xcargs_string = "-allowProvisioningUpdates CODE_SIGN_STYLE=Manual CODE_SIGN_IDENTITY='Apple Distribution' PROVISIONING_PROFILE='#{profile_uuid}'"

    build_app(
      workspace: "reedle.xcworkspace",
      scheme: "reedle",
      configuration: "Release",
      derived_data_path: "build",
      export_method: "app-store",
      xcargs: xcargs_string,
      export_options: {
        method: "app-store",
        signingStyle: "manual",
        stripSwiftSymbols: true,
        teamID: "244U6W36E7",
        provisioningProfiles: {
          bundle_id => profile_uuid
        }
      },
      output_directory: "build",
      output_name: "reedle.ipa"
    )
  end

  desc "Upload app to TestFlight"
  lane :upload_testflight do
    setup_ci if is_ci

    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
      key_filepath: File.expand_path("~/.appstoreconnect/private_keys/AuthKey_#{ENV['APP_STORE_CONNECT_API_KEY_ID']}.p8")
    )

    upload_to_testflight(
      api_key: api_key,
      ipa: "build/reedle.ipa",
      skip_waiting_for_build_processing: false,
      distribute_external: false
    )
  end

  desc "Export IPA from existing archive"
  lane :build_ipa_from_archive do
    setup_ci if is_ci

    build_app(
      workspace: "reedle.xcworkspace",
      scheme: "reedle",
      configuration: "Release",
      archive_path: "build/reedle.xcarchive",
      export_method: "app-store",
      skip_codesigning: true,
      export_options: {
        method: "app-store",
        signingStyle: "automatic",
        stripSwiftSymbols: true
      },
      output_directory: "build",
      output_name: "reedle.ipa",
      skip_build_archive: true,
      skip_package_ipa: false,
      skip_package_pkg: true,
      suppress_xcode_output: false
    )
  end

  desc "Build and upload to TestFlight (combined)"
  lane :build_and_upload_testflight do
    build_testflight
    upload_testflight
  end
end
